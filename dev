#!/usr/bin/env bash
set -e

COMPOSE_FILE="docker-compose.dev.yml"
COMPOSE_EXT="docker-compose.override.external.yml"
CONTAINER_NAME="m3u-editor-dev"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
NC='\033[0m'

usage() {
    echo -e "${CYAN}m3u-editor dev helper${NC}"
    echo ""
    echo "Usage: $0 <command>"
    echo ""
    echo -e "${GREEN}Startup:${NC}"
    echo "  up                 Start with embedded services (all-in-one)"
    echo "  up:external        Start with external postgres, redis, proxy"
    echo "  build              Build the container (no start)"
    echo "  build:up           Build and start with embedded services"
    echo "  build:external     Build and start with external services"
    echo ""
    echo -e "${YELLOW}Lifecycle:${NC}"
    echo "  down               Stop and remove containers"
    echo "  down:external      Stop and remove containers + external services"
    echo "  down:clean         Stop, remove containers AND volumes (fresh start)"
    echo "  restart            Restart the editor container"
    echo "  restart:all        Restart all containers (external mode)"
    echo ""
    echo -e "${CYAN}Development:${NC}"
    echo "  logs [lines]       Show logs (default: 100)"
    echo "  shell              Open shell in container"
    echo "  tinker             Open artisan tinker"
    echo "  test [filter]      Run tests (optional: filter by name)"
    echo "  ps                 Show all container status"
    echo ""
    echo -e "${CYAN}Examples:${NC}"
    echo "  $0 up              # Quick start, all embedded"
    echo "  $0 up:external     # Start with separate postgres/redis/proxy"
    echo "  $0 down:clean      # Nuke everything and start fresh"
    echo "  $0 test            # Run all tests"
    echo "  $0 test Playlist   # Run tests matching 'Playlist'"
}

compose_embedded() {
    docker compose -f $COMPOSE_FILE "$@"
}

compose_external() {
    docker compose -f $COMPOSE_FILE -f $COMPOSE_EXT "$@"
}

# Detect which mode is running
detect_mode() {
    if docker compose -f $COMPOSE_FILE -f $COMPOSE_EXT ps --quiet 2>/dev/null | grep -q .; then
        echo "external"
    elif docker compose -f $COMPOSE_FILE ps --quiet 2>/dev/null | grep -q .; then
        echo "embedded"
    else
        echo "none"
    fi
}

cleanup_legacy_containers() {
    # Remove old standalone containers from previous dev script
    for name in m3u-postgres-test-external m3u-redis-test-external m3u-proxy-test-external; do
        if docker ps -a --format '{{.Names}}' | grep -q "^${name}$"; then
            echo -e "${YELLOW}Removing legacy container: ${name}${NC}"
            docker rm -f "$name" 2>/dev/null || true
        fi
    done
}

case "$1" in
    build)
        echo -e "${YELLOW}Building m3u-editor container...${NC}"
        compose_embedded build m3u-editor-dev
        echo -e "${GREEN}Build complete${NC}"
        ;;

    build:up)
        echo -e "${YELLOW}Building and starting (embedded)...${NC}"
        compose_embedded up -d --build m3u-editor-dev
        echo -e "${GREEN}Started on http://localhost:36410${NC}"
        ;;

    build:external)
        cleanup_legacy_containers
        echo -e "${YELLOW}Building and starting (external services)...${NC}"
        compose_external up -d --build
        echo -e "${GREEN}Started on http://localhost:36410${NC}"
        ;;

    up)
        echo -e "${YELLOW}Starting m3u-editor (embedded)...${NC}"
        compose_embedded up -d m3u-editor-dev
        echo -e "${GREEN}Started on http://localhost:36410${NC}"
        ;;

    up:external)
        cleanup_legacy_containers
        echo -e "${YELLOW}Starting m3u-editor (external services)...${NC}"
        compose_external up -d
        echo -e ""
        echo -e "${GREEN}All services started:${NC}"
        compose_external ps --format "table {{.Name}}\t{{.Status}}\t{{.Ports}}"
        echo -e ""
        echo -e "${GREEN}App: http://localhost:36450${NC}"
        ;;

    down)
        echo -e "${YELLOW}Stopping containers...${NC}"
        compose_embedded down 2>/dev/null || true
        compose_external down 2>/dev/null || true
        echo -e "${GREEN}Done${NC}"
        ;;

    down:external)
        echo -e "${YELLOW}Stopping all containers (external mode)...${NC}"
        compose_external down 2>/dev/null || true
        echo -e "${GREEN}Done${NC}"
        ;;

    down:clean)
        echo -e "${RED}Stopping and removing all containers + volumes...${NC}"
        compose_external down -v 2>/dev/null || true
        compose_embedded down -v 2>/dev/null || true
        cleanup_legacy_containers
        echo -e "${GREEN}Clean slate. Run '$0 up' or '$0 up:external' to start fresh.${NC}"
        ;;

    restart)
        echo -e "${YELLOW}Restarting m3u-editor...${NC}"
        mode=$(detect_mode)
        if [ "$mode" = "external" ]; then
            compose_external restart m3u-editor-dev
        else
            compose_embedded restart m3u-editor-dev
        fi
        echo -e "${GREEN}Done${NC}"
        ;;

    restart:all)
        echo -e "${YELLOW}Restarting all containers...${NC}"
        compose_external restart
        echo -e "${GREEN}Done${NC}"
        ;;

    logs)
        LINES="${2:-100}"
        docker logs --tail "$LINES" -f $CONTAINER_NAME
        ;;

    shell)
        docker exec -it $CONTAINER_NAME /bin/bash
        ;;

    tinker)
        docker exec -it $CONTAINER_NAME php artisan tinker
        ;;

    test)
        FILTER="${2:-}"
        if [ -n "$FILTER" ]; then
            docker exec -it $CONTAINER_NAME php artisan test --compact --filter="$FILTER"
        else
            docker exec -it $CONTAINER_NAME php artisan test --compact
        fi
        ;;

    ps)
        mode=$(detect_mode)
        if [ "$mode" = "external" ]; then
            compose_external ps --format "table {{.Name}}\t{{.Status}}\t{{.Ports}}"
        elif [ "$mode" = "embedded" ]; then
            compose_embedded ps --format "table {{.Name}}\t{{.Status}}\t{{.Ports}}"
        else
            echo -e "${YELLOW}No containers running${NC}"
        fi
        ;;

    *)
        usage
        ;;
esac
